# ---------------------------------------------------------------------------
# Copy this file to `.env` and fill in your values:  cp .env.example .env
# ---------------------------------------------------------------------------

# REQUIRED — get a free key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# LLM model on Groq. The openai/gpt-oss family is the current production default
# (Groq deprecated the Llama chat models in mid-2026). Check the live list at
# https://console.groq.com/docs/models  — e.g. openai/gpt-oss-20b for a faster/cheaper run.
GROQ_MODEL=Grok_Model


LLM_TEMPERATURE=0.0

# Local embedding model (sentence-transformers). No API key needed; downloaded once.
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Vector store
CHROMA_PERSIST_DIR=./data/chroma
COLLECTION_NAME=tech_docs

# Chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

# Retrieval / self-correction
TOP_K=4
MAX_RETRIES=2

# --- Bonus features ---------------------------------------------------------
# Groundedness / hallucination check on generated answers (Self-RAG style).
ENABLE_HALLUCINATION_CHECK=true

# Web-search fallback via Tavily. Only active when BOTH the flag is true AND a key is set.
# Free key: https://tavily.com
ENABLE_WEB_SEARCH=false
TAVILY_API_KEY=
